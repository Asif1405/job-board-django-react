# ──────────────────────────────────────────────────────────────────────────────
# Job Board — Environment Variables
# Copy this file to .env and fill in the values before running the server.
# Never commit the real .env file to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Django core
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DB_NAME=jobboard
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT cookies — set to True in production (requires HTTPS)
COOKIE_SECURE=False

# Media / file storage (leave blank to use local disk)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=

# Redis (optional — for caching / Celery in future)
REDIS_URL=redis://localhost:6379/0

# Email (SMTP — only used in production)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@jobboard.example.com
